<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Math Center Fellow</title>

  <!-- bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-SgOJa3DmI69IUzQ2PVdRZhwQ+dy64/BUtbMJw1MZ8t5HZApcHrRKUc4W0kG879m7" crossorigin="anonymous">

  <!-- pt-serif -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=PT+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Roboto+Mono:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet">

  <!-- style sheet -->
  <link rel="stylesheet" href="style.css">
  <link rel="stylesheet" href="fellow-style.css">
</head>
<body>
  <nav>
    <a href="/" id="logo-a">
      <img src="https://www.westridge.org/uploaded/images/smallLogo.png" alt="westridge logo" id="logo">
    </a>
    <button>Today</button>
    <button>This Week</button>

    <form action="POST" class="d-flex flex-wrap align-items-center gap-3">
      <div class="form-group d-flex align-items-center">
        <label for="start-date" class="me-2">Start</label>
        <input id="start-date" name="start-date" type="date">
      </div>
      <div class="form-group d-flex align-items-center">
        <label for="end-date" class="me-2">End</label>
        <input type="date" id="end-date" name="end-date">
      </div>
      <div class="form-group d-flex align-items-center">
        <label for="rotation" class="me-2">Rotation</label>
        <select name="rotation" id="rotation">
          <option value="all">all</option>
          <option value="1">1</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="5">5</option>
          <option value="6">6</option>
        </select>
      </div>
    </form>
    
    
  </nav>

  <% console.log("start") %>

  

  <% const rotation = ["1", "2", "3", "4", "5", "6"] %>
  <%  console.log(days)%>
  
  <div class="accordion" id="accordionExample">
    <% days.forEach((day, i) => { %>
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button 
            class="accordion-button <%= i !== 0 ? 'collapsed' : '' %>" 
            type="button" 
            data-bs-toggle="collapse" 
            data-bs-target="#collapse<%= i %>" 
            aria-expanded="<%= i === 0 ? 'true' : 'false' %>" 
            aria-controls="collapse<%= i %>"
          >
            <%= day.date.toDateString() %> 
            <% if (rotation.includes(day.timeRotation)) { %> 
              Lunch
            <% } %> 
            <% if (day.timeRotation.split("-")[1] === "am") { %>
              Morning
            <% } %> 
            <% if (day.timeRotation.split("-")[1] === "pm") { %>
              Afterschool
            <% } %>
            Day:2
          </button>
        </h2>
  
        <div 
          id="collapse<%= i %>" 
          class="accordion-collapse collapse <%= i === 0 ? 'show' : '' %>" 
          aria-labelledby="heading<%= i %>" 
          data-bs-parent="#accordionExample"
        >
          <div class="accordion-body">
            <div class="card">
              <ul class="list-group list-group-flush">
                <li class="list-group-item">
                  <strong>Macomber, Caroline:</strong> Free 
                  <button class="btn btn-danger">Absent</button>
                </li>
                <li class="list-group-item">
                  <strong>Mermelstein, Maddie:</strong> meeting with Sabrina 
  
                  <button 
                    class="btn btn-primary" 
                    type="button" 
                    data-bs-toggle="collapse" 
                    data-bs-target="#details<%= i %>" 
                    aria-expanded="false" 
                    aria-controls="details<%= i %>"
                  >
                    Show Details
                  </button>
                  <div class="collapse" id="details<%= i %>">
                    <div class="card card-body">
                      Some placeholder content for the collapse component.
                    </div>
                  </div>
                </li>
                <li class="list-group-item">
                  <strong>Someone, Someone:</strong> absent
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
  

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js" integrity="sha384-k6d4wzSIapyDyv1kpU366/PK5hCdSbCRGRCMv+eplOQJWyd1fbcAu9OCUj5zNLiq" crossorigin="anonymous"></script>
</body>
</html>